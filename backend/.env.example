# ============================================================
# EMS Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control — it contains secrets.
#
# Quick start:
#   cp .env.example .env
#   then edit .env with your real values
# ============================================================


# Server 
NODE_ENV=development           # development | production | test
PORT=5000                      # Backend listens on this port


# Database 
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Docker Compose (local dev — matches docker-compose.yml):
DATABASE_URL=postgresql://ems_user:ems_password@localhost:5432/ems_db
#
# Render / Railway (production — paste the full URL they give you):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require


#JWT Access Token 
# Used for protecting API routes. Short-lived (15 min).
# CHANGE THIS to a random 64-char string before deploying to prod.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_a_long_random_string_at_least_64_chars_in_production
JWT_EXPIRE=15m                 # e.g. 15m, 1h, 2h


# JWT Refresh Token 
# Used to issue new access tokens without re-login. Longer-lived.
# MUST be different from JWT_SECRET.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
REFRESH_TOKEN_SECRET=CHANGE_ME_another_long_random_string_different_from_jwt_secret
REFRESH_TOKEN_EXPIRE=7d        # e.g. 7d, 30d


# Bcrypt 
# Cost factor for password hashing. 12 is strong; 10 is faster for dev.
# Higher = slower hash (but more secure). Don't go below 10.
BCRYPT_ROUNDS=12


# CORS 
# Comma-separated list of allowed frontend origins.
# Dev: Vite default port is 5173.
# Prod: replace with your actual deployed frontend URL.
CORS_ORIGIN=http://localhost:5173


# Cookie 
# Set to true in production so refresh token cookie is only sent over HTTPS.
# Keep false for local dev (HTTP).
COOKIE_SECURE=false


# QR Attendance — Phase 4
# Used to HMAC-sign attendee QR payloads so they cannot be forged.
# MUST be different from JWT_SECRET and REFRESH_TOKEN_SECRET.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
HMAC_SECRET=CHANGE_ME_use_a_long_random_string_at_least_64_chars_in_production

# Minutes after session start at which a check-in becomes "Late" instead of "Present".
LATE_THRESHOLD_MINUTES=15


# Deployment Notes (Render / Railway)
# 1. Set NODE_ENV=production
# 2. Set DATABASE_URL from the platform's managed PostgreSQL panel
# 3. Regenerate JWT_SECRET, REFRESH_TOKEN_SECRET, and HMAC_SECRET with the command above
# 4. Set CORS_ORIGIN to your Vercel/Netlify/Render frontend URL
# 5. Set COOKIE_SECURE=true (HTTPS is enforced on these platforms)
