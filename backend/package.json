{
   "name": "ems-backend",
   "version": "1.0.0",
   "description": "Event Management System — Node.js/Express/PostgreSQL backend",
   "main": "server.js",
   "type": "commonjs",
   "scripts": {
      "dev": "nodemon server.js",
      "start": "node server.js",
      "db:migrate": "sequelize-cli db:migrate",
      "db:migrate:undo": "sequelize-cli db:migrate:undo",
      "db:seed": "node scripts/seedDevUsers.js",
      "db:reset": "sequelize-cli db:migrate:undo:all && sequelize-cli db:migrate && node scripts/seedDevUsers.js",
      "lint": "eslint ."
   },
   "dependencies": {
      "bcrypt": "^6.0.0",
      "bcryptjs": "^2.4.3",
      "cookie-parser": "^1.4.7",
      "cors": "^2.8.5",
      "csv-parser": "^3.2.1",
      "dotenv": "^16.5.0",
      "express": "^4.21.2",
      "express-rate-limit": "^7.5.0",
      "joi": "^17.13.3",
      "jsonwebtoken": "^9.0.2",
      "jspdf": "^4.2.1",
      "jspdf-autotable": "^5.0.8",
      "morgan": "^1.10.0",
      "multer": "^2.1.1",
      "nodemailer": "^8.0.10",
      "papaparse": "^5.5.3",
      "pg": "^8.21.0",
      "pg-hstore": "^2.3.4",
      "sequelize": "^6.37.8",
      "xlsx": "^0.18.5"
   },
   "devDependencies": {
      "eslint": "^10.4.0",
      "nodemon": "^3.1.10",
      "sequelize-cli": "^6.6.2"
   },
   "engines": {
      "node": ">=20.0.0"
   }
}
